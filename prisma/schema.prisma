generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  ESTIMATING
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  PHONE
  REFERRAL
  ADS
  OTHER
}

model User {
  id             String      @id @default(cuid())
  name           String?
  email          String      @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           UserRole    @default(MANAGER)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?   @db.Text
  twoFactorRecoveryCodes String? @db.LongText
  accounts       Account[]
  sessions       Session[]
  assignedLeads  Lead[]      @relation("AssignedManager")
  leadNotes      LeadNote[]
  leadActivities LeadActivity[]
  passwordResetTokens PasswordResetToken[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Lead {
  id             String           @id @default(cuid())
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  zipCode        String?
  projectType    String?
  projectSummary String?          @db.Text
  budget         String?
  source         LeadSource       @default(WEBSITE)
  status         LeadStatus       @default(NEW)
  assignedToId   String?
  assignedTo     User?            @relation("AssignedManager", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes          LeadNote[]
  activities     LeadActivity[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model SiteSettings {
  id          String   @id @default("default")
  brandBlue   String   @default("#3348ff")
  brandDark   String   @default("#14162b")
  brandSoft   String   @default("#edf2f8")
  brandAccent String   @default("#f0c62e")
  logoData    String?  @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadNote {
  id        String   @id @default(cuid())
  body      String   @db.Text
  leadId    String
  authorId  String?
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([leadId])
}

model LeadActivity {
  id          String   @id @default(cuid())
  type        String
  description String?  @db.Text
  leadId      String
  authorId    String?
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([leadId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TwoFactorLoginToken {
  id             String   @id @default(cuid())
  email          String
  tokenHash      String   @unique @db.VarChar(191)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique @db.VarChar(191)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
